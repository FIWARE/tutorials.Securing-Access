#!/bin/bash
#
#  Command Line Interface to start all services associated with the Tutorial
#
#  For this tutorial the commands are merely a convenience script to run docker or docker-compose
#
#  Each services script can be run using either docker-compose (the external tool with the hyphen -)
#  or docker compose (the newer version directly bundled with Docker with a space)
#
#  if you start up with the following command:
#
#  ./services start legacy
#
# This will force the script to use docker-compose which may be more reliable in
# some cases (or if an older version of Docker is being used)

set -e

dockerCmd="docker compose"
if (( $# == 2 )); then
    dockerCmd="docker-compose"
fi

if (( $# < 1 )); then
    echo "Illegal number of parameters"
    echo "usage: services [create|start|stop]"
    exit 1
fi

displayServices () {
    echo ""
    docker ps --format "table {{.Names}}\t{{.Status}}\t{{.Ports}}" --filter name="$1"
    echo ""
}

stoppingContainers () {
    CONTAINERS=$(docker ps --filter "label=org.fiware=tutorial" -aq)
    if [[ -n $CONTAINERS ]]; then
        echo "Stopping containers"
        docker rm -f $CONTAINERS || true
    fi
    VOLUMES=$(docker volume ls -qf dangling=true)
    if [[ -n $VOLUMES ]]; then
        echo "Removing old volumes"
        docker volume rm $VOLUMES || true
    fi
    NETWORKS=$(docker network ls --filter "label=org.fiware=tutorial" -q)
    if [[ -n $NETWORKS ]]; then
        echo "Removing tutorial networks"
        docker network rm $NETWORKS || true
    fi
}

waitForKeycloak () {
    echo -e "\n⏳ Waiting for \033[1;34mKeycloak\033[0m to be available\n"
    while ! [ "$(docker inspect --format='{{.State.Health.Status}}' fiware-keycloak 2>/dev/null)" == "healthy" ]
    do
        echo -e "Keycloak health: $(docker inspect --format='{{.State.Health.Status}}' fiware-keycloak 2>/dev/null) (waiting for healthy)"
        sleep 5
    done
    echo -e " \033[1;32mdone\033[0m"
}

waitForOrion () {
    echo -e "\n⏳ Waiting for \033[1;34mOrion-LD\033[0m to be available\n"
    while ! [ "$(docker inspect --format='{{.State.Health.Status}}' fiware-orion 2>/dev/null)" == "healthy" ]
    do
        echo -e "Orion health: $(docker inspect --format='{{.State.Health.Status}}' fiware-orion 2>/dev/null) (waiting for healthy)"
        sleep 5
    done
    echo -e " \033[1;32mdone\033[0m"
}

waitForTutorial () {
    echo -e "\n⏳ Waiting for \033[1mTutorial\033[0m to be available\n"
    while ! [ "$(docker inspect --format='{{.State.Health.Status}}' fiware-tutorial 2>/dev/null)" == "healthy" ]
    do
        echo -e "Tutorial health: $(docker inspect --format='{{.State.Health.Status}}' fiware-tutorial 2>/dev/null) (waiting for healthy)"
        sleep 5
    done
    echo -e " \033[1;32mdone\033[0m"
}

waitForIoTAgent () {
    echo -e "\n⏳ Waiting for \033[1;36mIoT-Agent\033[0m to be available\n"
    while [ "$(docker run --network fiware_default --rm "quay.io/curl/curl:${CURL_VERSION}" -s -o /dev/null -w '%{http_code}' 'http://iot-agent:4041/version')" -eq 000 ]
    do
        echo -e "IoT Agent HTTP state: 000 (waiting for 200)"
        sleep 6
    done
    echo -e " \033[1;32mdone\033[0m"
}

loadData () {
    docker run --rm \
        --network fiware_default \
        -v "$(pwd)/import-data:/import-data" \
        -v "$(pwd)/data:/home/curl_user/data" \
        -e CONTEXT_BROKER=orion:1026 \
        -e IOT_DEVICES=http://iot-sensors:3001 \
        -e TUTORIAL_DATA_MODELS_CONTEXT=http://context/ngsi-context.jsonld \
        --entrypoint /bin/ash \
        "quay.io/curl/curl:${CURL_VERSION}" /import-data
    waitForIoTAgent
    docker run --rm \
        --network fiware_default \
        -v "$(pwd)/provision-devices:/provision-devices" \
        --entrypoint /bin/ash \
        "quay.io/curl/curl:${CURL_VERSION}" /provision-devices
    docker run --rm \
        --network fiware_default \
        -v "$(pwd)/link-devices:/link-devices" \
        --entrypoint /bin/ash \
        "quay.io/curl/curl:${CURL_VERSION}" /link-devices
}

loadUsers () {
    docker run --rm \
        --network fiware_default \
        -v "$(pwd)/import_users:/import_users" \
        -e KEYCLOAK_HOST=keycloak \
        -e KEYCLOAK_PORT=8080 \
        --entrypoint /bin/sh \
        python:3-alpine -c "apk add --no-cache curl && /import_users"
}

command="$1"
case "${command}" in
    "help")
        echo "usage: services [create|start|stop]"
        ;;
    "start")
        export $(cat .env | grep "#" -v)
        stoppingContainers
        echo -e "Starting containers: \033[1;34mKeycloak\033[0m, \033[1;34mOrion-LD\033[0m, a \033[1mTutorial\033[0m application, a \033[1mContext\033[0m server, \033[1mPostgreSQL\033[0m and \033[1mMongoDB\033[0m databases."
        echo -e "- \033[1;34mKeycloak\033[0m is the Identity and Access Management server"
        echo -e "- \033[1;34mOrion-LD\033[0m is the NGSI-LD context broker"
        echo -e "- \033[1mTutorial\033[0m is the farm management web application"
        echo ""
        ${dockerCmd} up -d --remove-orphans
        displayServices fiware
        waitForKeycloak
        loadUsers
        waitForOrion
        waitForTutorial
        loadData
        echo -e "\033[1;34mKeycloak\033[0m is now running and exposed on localhost:${KEYCLOAK_PORT}"
        echo -e "Now open \033[4mhttp://localhost:${TUTORIAL_APP_PORT}\033[0m"
        ;;
    "stop")
        export $(cat .env | grep "#" -v)
        stoppingContainers
        ;;
    "create")
        export $(cat .env | grep "#" -v)
        echo "Pulling Docker images"
        docker pull -q "quay.io/curl/curl:${CURL_VERSION}"
        ${dockerCmd} pull --ignore-pull-failures
        ;;
    *)
        echo "Command not Found."
        echo "usage: services [create|start|stop]"
        exit 127;
        ;;
esac
