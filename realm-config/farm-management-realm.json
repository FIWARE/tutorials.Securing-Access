{
  "id": "farm-management",
  "realm": "farm-management",
  "displayName": "Farm Management System",
  "enabled": true,
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "accessTokenLifespan": 300,
  "groups": [
    { "name": "farm-management",     "path": "/farm-management"     },
    { "name": "livestock-team",      "path": "/livestock-team"      },
    { "name": "crop-team",           "path": "/crop-team"           },
    { "name": "equipment-team",      "path": "/equipment-team"      },
    { "name": "external-consultants","path": "/external-consultants"}
  ],
  "roles": {
    "realm": [
      { "name": "farm-manager",         "description": "Full read/write access to all farm context data and commands" },
      { "name": "livestock-supervisor", "description": "Read/write access to Animal, Water and FillingLevelSensor entities" },
      { "name": "crop-supervisor",      "description": "Read/write access to Field, SoilSensor and WeatherObserved entities" },
      { "name": "equipment-supervisor", "description": "Read/write access to Tractor entities" },
      { "name": "field-worker",         "description": "Write measurements, read own-domain entities" },
      { "name": "read-only-consultant", "description": "Read-only access to all entity types" }
    ]
  },
  "clients": [
    {
      "clientId": "ngsi-ld-farm",
      "name": "NGSI-LD Farm Management Application",
      "enabled": true,
      "publicClient": false,
      "secret": "1234",
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": [
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000"
      ],
      "authorizationSettings": {
        "allowRemoteResourceManagement": false,
        "policyEnforcementMode": "ENFORCING",
        "resources": [
          {
            "name": "Entity Collection",
            "displayName": "NGSI-LD Entity Collection Endpoint",
            "uris": ["/ngsi-ld/v1/entities", "/ngsi-ld/v1/entities/*"],
            "scopes": [
              { "name": "GET"    },
              { "name": "POST"   },
              { "name": "PATCH"  },
              { "name": "DELETE" }
            ]
          }
        ],
        "scopes": [
          { "name": "GET"    },
          { "name": "POST"   },
          { "name": "PATCH"  },
          { "name": "DELETE" }
        ],
        "policies": [
          {
            "name": "Farm Manager Policy",
            "type": "role",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": { "roles": "[{\"id\":\"farm-manager\",\"required\":false}]" }
          },
          {
            "name": "Livestock Supervisor Policy",
            "type": "role",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": { "roles": "[{\"id\":\"livestock-supervisor\",\"required\":false}]" }
          },
          {
            "name": "Read Only Consultant Policy",
            "type": "role",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": { "roles": "[{\"id\":\"read-only-consultant\",\"required\":false}]" }
          },
          {
            "name": "Farm Managers can write all entities",
            "type": "scope",
            "logic": "POSITIVE",
            "decisionStrategy": "AFFIRMATIVE",
            "config": {
              "resources": "[\"Entity Collection\"]",
              "scopes": "[\"POST\",\"PATCH\",\"DELETE\"]",
              "applyPolicies": "[\"Farm Manager Policy\",\"Livestock Supervisor Policy\"]"
            }
          },
          {
            "name": "All authenticated users can read entities",
            "type": "scope",
            "logic": "POSITIVE",
            "decisionStrategy": "AFFIRMATIVE",
            "config": {
              "resources": "[\"Entity Collection\"]",
              "scopes": "[\"GET\"]",
              "applyPolicies": "[\"Farm Manager Policy\",\"Livestock Supervisor Policy\",\"Read Only Consultant Policy\"]"
            }
          }
        ]
      }
    }
  ]
}
